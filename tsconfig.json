{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "typeRoots": [
      "./src/custom.d.ts",
      "./node_modules/@types"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/hooks/usePdfDownloader.js",
    "src/hooks/usePowerActions.js",
    "src/services/extension/ApiHelper.js",
    "src/services/extension/HttpClientServices.js",
    "src/services/extension/loadingService.js",
    "src/services/main/KioskServices.js"
  ]
}