{
  "name": "a101-kiosk",
  "version": "1.0.0",
  "main": "src/main/main.js",
  "scripts": {
    "react:start": "webpack serve --mode=development --hot",
    "build-renderer": "cross-env NODE_ENV=production webpack --mode=production",
    "start:dev": "concurrently -k --handle-input \"npm run react:start\" \"wait-on http://localhost:8080 && cross-env ELECTRON_START_URL=http://localhost:8080 electron .\"",
    "start": "npm run build-renderer && electron .",
    "rebuild:native": "npx @electron/rebuild -f -w sqlite3",
    "dist:windows": "npm run build-renderer && npm run rebuild:native && electron-builder --win",
    "dist:linux": "npm run build-renderer && npm run rebuild:native && electron-builder --linux",
    "dist": "npm run build-renderer && npm run rebuild:native && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.2",
    "@mui/material": "^7.1.2",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.0",
    "electron-localshortcut": "^3.2.1",
    "html-webpack-plugin": "^5.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.22.2",
    "sqlite3": "^5.1.7",
    "wait-on": "^8.0.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^37.0.0",
    "electron-builder": "^24.13.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack-dev-server": "^5.2.2"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": false,
    "appId": "com.a101.electroninv",
    "productName": "ElectronInv",
    "directories": {
      "buildResources": "src/assets/img"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "icon": "a-101-logo.ico",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "a-101-logo.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "a-101-logo.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "a-101-logo.ico",
      "uninstallerIcon": "a-101-logo.ico",
      "installerHeaderIcon": "a-101-logo.ico"
    }
  }
}